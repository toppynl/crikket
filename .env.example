# Copy this file to .env and edit values for your environment.
# Docker Compose automatically reads .env from the project root.

# Published ports on host
WEB_PORT=3001
SERVER_PORT=3000
POSTGRES_PORT=5432

# Self-host database mode
CRIKKET_DATABASE_MODE=bundled

# Optional built-in Caddy reverse proxy
CRIKKET_PROXY_MODE=
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_ACME_EMAIL=
CADDY_PUBLIC_HOST=

# Optional: bundled postgres service settings only
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crikket
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
