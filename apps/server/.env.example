NODE_ENV=development

# ==========================================
# DATABASE & INFRASTRUCTURE
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/crikket
# Comma-delimited allowed origins used by both CORS and Better Auth trusted origins.
CORS_ORIGINS=http://localhost:3001

# ==========================================
# RATE LIMITING (Upstash Redis)
# ==========================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==========================================
# AUTHENTICATION (Better Auth)
# ==========================================
BETTER_AUTH_SECRET=your_generated_secret_here
BETTER_AUTH_URL=http://localhost:3000
# Optional. Set this if you want auth cookies shared across subdomains.
# e.g. if your app is at sh.example.com and you want root-domain cookies, set this to example.com
BETTER_AUTH_COOKIE_DOMAIN=

# Email setup
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# ==========================================
# OAuth Providers - Optional
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NOTE:
# In your OAuth2 apps, set callback/redirect URIs to `<domain>/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/google

# ==========================================
# PAYMENTS & MONETIZATION (Polar.sh) - Optional
# ==========================================
POLAR_ACCESS_TOKEN=your_polar_token_here
POLAR_SUCCESS_URL=http://localhost:3001/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_PRO_PRODUCT_ID=your_polar_pro_product_id
POLAR_PRO_YEARLY_PRODUCT_ID=your_polar_pro_yearly_product_id
POLAR_STUDIO_PRODUCT_ID=your_polar_studio_product_id
POLAR_STUDIO_YEARLY_PRODUCT_ID=your_polar_studio_yearly_product_id
ENABLE_PAYMENTS=true

# ==========================================
# STORAGE
# ==========================================
# Cloud storage is required in all environments.
# Required:
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Required for AWS S3 when endpoint is not set.
# Example: us-east-1
STORAGE_REGION=

# Optional for AWS S3, typically required for R2.
# Examples:
# AWS S3: https://s3.us-east-1.amazonaws.com
# R2: https://<accountid>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=

# Optional public base URL to avoid signed URLs.
# Example: https://cdn.example.com/bug-reports
STORAGE_PUBLIC_URL=

# ==========================================
# CAPTURE SECURITY (Turnstile & submit tokens) - Optional
# ==========================================
# Enables signed capture submit tokens when set.
# Upstash Redis is optional; when configured it enables rate limiting
# and one-time submit token replay protection.
# Turnstile is optional and only enforced when both keys are set.
CAPTURE_SUBMIT_TOKEN_SECRET=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
