NODE_ENV=development

# ==========================================
# DATABASE & INFRASTRUCTURE
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/crikket
# Comma-delimited allowed origins used by both CORS and Better Auth trusted origins.
CORS_ORIGINS=http://localhost:3001

# ==========================================
# AUTHENTICATION (Better Auth)
# ==========================================
BETTER_AUTH_SECRET=your_generated_secret_here
BETTER_AUTH_URL=http://localhost:3000
# Email setup
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# ==========================================
# OAuth Providers - Optional
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NOTE:
# In your OAuth2 apps, set callback/redirect URIs to `<domain>/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/google

# ==========================================
# PAYMENTS & MONETIZATION (Polar.sh) - Optional
# ==========================================
POLAR_ACCESS_TOKEN=your_polar_token_here
POLAR_SUCCESS_URL=http://localhost:3001/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_PRODUCT_ID=your_polar_product_id
ENABLE_PAYMENTS=true

# ==========================================
# STORAGE
# ==========================================
# Provider priority:
# 1) If STORAGE_PROVIDER=auto and cloud credentials are present, cloud is used.
# 2) Otherwise local storage is used.
# Set STORAGE_PROVIDER=s3 or r2 to force cloud and fail fast if misconfigured.
STORAGE_PROVIDER=auto
# Leave these empty when using cloud storage.
STORAGE_PATH=../../storage
STORAGE_BASE_URL=/uploads

# Shared cloud storage settings (S3 or R2)
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=
STORAGE_USE_PATH_STYLE=false

# AWS S3:
# STORAGE_PROVIDER=s3
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=

# Cloudflare R2:
# STORAGE_PROVIDER=r2
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
