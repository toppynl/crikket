{
  "name": "@crikket/capture-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./debugger/constants": {
      "types": "./dist/debugger/constants.d.ts",
      "default": "./dist/debugger/constants.js"
    },
    "./debugger/types": {
      "types": "./dist/debugger/types.d.ts",
      "default": "./dist/debugger/types.js"
    },
    "./debugger/normalize": {
      "types": "./dist/debugger/normalize.d.ts",
      "default": "./dist/debugger/normalize.js"
    },
    "./debugger/payload": {
      "types": "./dist/debugger/payload.d.ts",
      "default": "./dist/debugger/payload.js"
    },
    "./debugger/recorder-session": {
      "types": "./dist/debugger/recorder-session.d.ts",
      "default": "./dist/debugger/recorder-session.js"
    },
    "./debugger/engine/background/retention": {
      "types": "./dist/debugger/engine/background/retention.d.ts",
      "default": "./dist/debugger/engine/background/retention.js"
    },
    "./debugger/engine/page": {
      "types": "./dist/debugger/engine/page/index.d.ts",
      "default": "./dist/debugger/engine/page/index.js"
    },
    "./debugger/engine/page/types": {
      "types": "./dist/debugger/engine/page/types.d.ts",
      "default": "./dist/debugger/engine/page/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@crikket/config": "workspace:*",
    "typescript": "catalog:"
  }
}
