{
  "name": "@crikket/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@crikket/config": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
